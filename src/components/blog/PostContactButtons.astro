---
interface Props {
  phone?: string;
  whatsapp?: string;
  whatsappMessage?: string;
  title?: string;
}

const {
  phone = "966543441970",
  whatsapp = "966543441970",
  whatsappMessage = "مرحبًا، أريد الاستفسار عن الخدمة",
  title = "هل تحتاج إلى هذه الخدمة؟",
} = Astro.props;

const cleanPhone = phone.replace(/[^\d+]/g, "");
const cleanWhatsapp = whatsapp.replace(/\D/g, "");

const whatsappUrl =
  `https://wa.me/${cleanWhatsapp}?text=${encodeURIComponent(whatsappMessage)}`;
---

<section class="post-contact-box" aria-label="خيارات التواصل">
  <div class="contact-content">
    <div class="contact-text">
      <span class="contact-label">تواصل معنا</span>
      <h2>{title}</h2>
      <p>احصل على استشارة ومعاينة للخدمة، وسنساعدك في اختيار الحل المناسب.</p>
    </div>

    <div class="contact-actions">
      <a
        href={whatsappUrl}
        class="contact-button whatsapp-button"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="التواصل عبر واتساب"
        data-contact-action="whatsapp"
      >
        <svg
          viewBox="0 0 24 24"
          aria-hidden="true"
          width="22"
          height="22"
        >
          <path
            fill="currentColor"
            d="M16.75 13.96c-.25-.13-1.47-.72-1.7-.8-.23-.09-.4-.13-.56.12-.17.25-.65.8-.8.97-.15.17-.29.19-.54.06a6.84 6.84 0 0 1-2-1.23 7.47 7.47 0 0 1-1.39-1.73c-.15-.25-.02-.38.11-.51.12-.12.25-.29.38-.44.12-.15.16-.25.25-.42.08-.17.04-.32-.02-.44-.07-.13-.57-1.37-.78-1.87-.2-.49-.41-.42-.56-.43h-.48c-.17 0-.44.06-.67.31-.23.25-.88.86-.88 2.1s.9 2.44 1.03 2.61c.12.17 1.77 2.7 4.29 3.79.6.26 1.07.41 1.43.53.6.19 1.15.16 1.58.1.48-.07 1.47-.6 1.68-1.18.21-.59.21-1.09.15-1.19-.06-.1-.23-.17-.48-.29ZM12.04 2a9.84 9.84 0 0 0-8.42 14.93L2.05 22l5.2-1.52A9.94 9.94 0 1 0 12.04 2Zm0 17.98a8.1 8.1 0 0 1-4.13-1.13l-.3-.18-3.08.9.92-3-.19-.31a8.07 8.07 0 1 1 6.78 3.72Z"
          />
        </svg>

        <span>تواصل عبر واتساب</span>
      </a>

      <a
        href={`tel:${cleanPhone}`}
        class="contact-button call-button"
        aria-label="الاتصال الهاتفي"
        data-contact-action="phone"
      >
        <svg
          viewBox="0 0 24 24"
          aria-hidden="true"
          width="21"
          height="21"
        >
          <path
            fill="currentColor"
            d="M6.62 10.79a15.46 15.46 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.01-.24 11.5 11.5 0 0 0 3.58.57 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.61 21 3 13.39 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 11.5 11.5 0 0 0 .57 3.58 1 1 0 0 1-.25 1.01l-2.2 2.2Z"
          />
        </svg>

        <span>اتصل بنا الآن</span>
      </a>
    </div>
  </div>
</section>

<style>
  .post-contact-box {
    margin: 2.5rem 0;
    padding: 1.5rem;
    border: 1px solid #e5e7eb;
    border-radius: 1.25rem;
    background:
      radial-gradient(
        circle at top right,
        rgba(34, 197, 94, 0.12),
        transparent 42%
      ),
      #ffffff;
    box-shadow: 0 12px 35px rgba(15, 23, 42, 0.08);
  }

  .contact-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .contact-text {
    flex: 1;
  }

  .contact-label {
    display: inline-block;
    margin-bottom: 0.5rem;
    color: #15803d;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .contact-text h2 {
    margin: 0 0 0.5rem;
    color: #111827;
    font-size: clamp(1.3rem, 2.5vw, 1.75rem);
    line-height: 1.4;
  }

  .contact-text p {
    margin: 0;
    color: #64748b;
    font-size: 0.98rem;
    line-height: 1.8;
  }

  .contact-actions {
    display: flex;
    flex-shrink: 0;
    gap: 0.75rem;
  }

  .contact-button {
    display: inline-flex;
    min-height: 50px;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    padding: 0.8rem 1.15rem;
    border-radius: 0.85rem;
    color: #ffffff;
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1;
    text-decoration: none;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      opacity 0.2s ease;
  }

  .contact-button:hover {
    color: #ffffff;
    transform: translateY(-2px);
  }

  .contact-button:focus-visible {
    outline: 3px solid rgba(37, 99, 235, 0.25);
    outline-offset: 3px;
  }

  .whatsapp-button {
    background: linear-gradient(135deg, #25d366, #16a34a);
    box-shadow: 0 8px 20px rgba(37, 211, 102, 0.25);
  }

  .call-button {
    background: linear-gradient(135deg, #2563eb, #1d4ed8);
    box-shadow: 0 8px 20px rgba(37, 99, 235, 0.22);
  }

  .contact-button svg {
    flex: 0 0 auto;
  }

  @media (max-width: 780px) {
    .contact-content {
      align-items: stretch;
      flex-direction: column;
    }

    .contact-actions {
      display: grid;
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 520px) {
    .post-contact-box {
      padding: 1.15rem;
      border-radius: 1rem;
    }

    .contact-actions {
      grid-template-columns: 1fr;
    }

    .contact-button {
      width: 100%;
    }
  }
</style>