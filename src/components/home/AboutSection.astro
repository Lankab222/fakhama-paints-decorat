---
interface Props {
  badge?: string;
  title: string;
  description: string;

  image?: string;
  imageAlt?: string;

  buttonText?: string;
  buttonUrl?: string;

  features?: string[];
}

const {
  badge,
  title,
  description,
  image,
  imageAlt,
  buttonText,
  buttonUrl,
  features = [],
} = Astro.props;
---

<section class="section about-section">
  <div class="container about-grid">
    {
      image && (
        <div class="about-media">
          <img
            src={image}
            alt={imageAlt || title}
            width="900"
            height="760"
            loading="lazy"
            decoding="async"
          />

          <div class="about-media__badge">
            <span>نحن مؤسسة متخصصة في تقديم أفضل الدهانات والديكورات</span>
          </div>
        </div>
      )
    }

    <div class="about-content">
      <!-- {badge && <span class="eyebrow">{badge}</span>} -->

      <h2>{title}</h2>

      <p>{description}</p>

      {
        features.length > 0 && (
          <ul class="about-features">
            {features.map((feature) => (
              <li>
                <span aria-hidden="true">✓</span>
                {feature}
              </li>
            ))}
          </ul>
        )
      }

      {
        buttonText && buttonUrl && (
          <a class="about-button" href={buttonUrl}>
            {buttonText}
            <span aria-hidden="true">←</span>
          </a>
        )
      }
    </div>
  </div>
</section>

<style>
  .about-section {
    background: var(--color-surface);
  }

  .about-grid {
    display: grid;
    gap: 2.5rem;
    align-items: center;
  }

  .about-media {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: 2rem;
    background: var(--color-background);
    box-shadow: var(--shadow-md);
  }

  .about-media img {
    width: 100%;
    aspect-ratio: 6 / 5;
    object-fit: cover;
  }

  .about-media__badge {
    position: absolute;
    right: 1rem;
    bottom: 1rem;
    gap: 0.15rem;
    max-width: 100%;
    padding: 1rem;
    border: 1px solid rgba(121, 94, 5, 0.842);
    border-radius: var(--radius-md);
    background: rgb(255, 234, 50);
    box-shadow: var(--shadow-md);
    backdrop-filter: blur(12px);
  }

  .about-media__badge span {
    color: var(--color-text-muted);
    font-size: 1.1rem;
    font-weight: bold;
  }

  .about-content {
    max-width: 720px;
    text-align: center;
  }

  .eyebrow {
    color: var(--color-primary);
    font-weight: bold;
    font-size: 1.1rem;
  }

  .about-content h2 {
    margin-block: 0.6rem 1rem;
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.25;
  }

  .about-content > p {
    color: var(--color-text-muted);
    font-size: 1.075rem;
  }

  .about-features {
    display: grid;
    gap: 0.8rem;
    margin-block: 1.5rem;
    padding: 0;
    list-style: none;
  }

  .about-features li {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    font-weight: 700;
  }

  .about-features span {
    display: grid;
    width: 1.6rem;
    height: 1.6rem;
    flex: 0 0 auto;
    place-items: center;
    border-radius: 50%;
    background:
      color-mix(in srgb, var(--color-primary) 12%, transparent);
    color: var(--color-primary);
  }

  .about-button {
    display: inline-flex;
    min-height: 50px;
    align-items: center;
    gap: 0.55rem;
    padding-inline: 1.25rem;
    border-radius: var(--radius-md);
    background: var(--color-primary);
    color: white;
    font-weight: 800;
  }

  @media (min-width: 900px) {
    .about-grid {
      grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
      gap: clamp(3rem, 6vw, 6rem);
    }
  }
</style>