---
import JsonLd from "./JsonLd.astro";

interface Props {
  name: string;
  description: string;
  url: string;
  image?: string;
  providerName: string;
  providerUrl: string;
  areaServed?: string;
}

const {
  name,
  description,
  url,
  image,
  providerName,
  providerUrl,
  areaServed,
} = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",

  name,
  description,
  url,

  ...(image ? { image } : {}),

  provider: {
    "@type": "Organization",
    name: providerName,
    url: providerUrl,
  },

  ...(areaServed
    ? {
        areaServed: {
          "@type": "AdministrativeArea",
          name: areaServed,
        },
      }
    : {}),

  inLanguage: "ar",
};
---

<JsonLd data={schema} />