---
interface Props {
  phone?: string;
  whatsapp?: string;
  email?: string;
  facebook?: string;
  instagram?: string;
  x?: string;
}

const { phone, whatsapp, email, facebook, instagram, x } = Astro.props;
const cleanPhone = phone?.replace(/[^\d+]/g, "");
const cleanWhatsapp = whatsapp?.replace(/\D/g, "");

const items = [
  {
    label: "واتساب",
    href: cleanWhatsapp ? `https://wa.me/${cleanWhatsapp}` : undefined,
    className: "whatsapp",
    icon: "whatsapp",
    external: true,
  },
  {
    label: "اتصال",
    href: cleanPhone ? `tel:${cleanPhone}` : undefined,
    className: "phone",
    icon: "phone",
    external: false,
  },
  {
    label: "إنستغرام",
    href: instagram || undefined,
    className: "instagram",
    icon: "instagram",
    external: true,
  },
  
  {
    label: "البريد",
    href: email ? `mailto:${email}` : undefined,
    className: "email",
    icon: "email",
    external: false,
  },
  {
    label: "منصة X",
    href: x || undefined,
    className: "x",
    icon: "x",
    external: true,
  },
  {
    label: "فيسبوك",
    href: facebook || undefined,
    className: "facebook",
    icon: "facebook",
    external: true,
  },
  
  
].filter(
  (
    item,
  ): item is typeof item & {
    href: string;
  } => Boolean(item.href),
);

---

{
  items.length > 0 && (
    <aside class="floating-socials" aria-label="روابط التواصل السريعة">
      {items.map((item) => (
        <a
          class={`floating-socials__link ${item.className}`}
          href={item.href}
          aria-label={item.label}
          title={item.label}
          target={item.external ? "_blank" : undefined}
          rel={item.external ? "noopener noreferrer" : undefined}
        >
          {item.icon === "whatsapp" && (
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path
                d="M20.5 11.8a8.4 8.4 0 0 1-12.4 7.4L3 20.5l1.4-4.9a8.4 8.4 0 1 1 16.1-3.8Z"
                fill="none"
                stroke="currentColor"
                stroke-width="1.9"
                stroke-linejoin="round"
              />
              <path
                d="M8.2 7.7c.3-.5.6-.5.9-.5h.4c.2 0 .4.1.5.4l.8 1.9c.1.3 0 .5-.1.7l-.6.8c-.2.2-.2.4 0 .7.5.9 1.2 1.6 2.1 2.1.3.2.5.2.7 0l.9-1c.2-.2.4-.2.7-.1l1.9.9c.3.1.4.3.4.5 0 .5-.2 1.4-.7 1.9-.5.5-1.3.8-2.1.7-1.1-.1-2.5-.6-4.2-2.1-2-1.8-3.2-4-3.3-5.3-.1-.7.2-1.2.7-1.6Z"
                fill="currentColor"
              />
            </svg>
          )}

          {item.icon === "phone" && (
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path
                d="M6.6 3.5 9 3c.6-.1 1.1.2 1.3.8l1.1 3.1c.2.5 0 1-.4 1.3L9.5 9.4a14 14 0 0 0 5.1 5.1l1.2-1.5c.3-.4.8-.6 1.3-.4l3.1 1.1c.6.2.9.7.8 1.3l-.5 2.4c-.2 1-1.1 1.7-2.1 1.6C11.2 18.4 5.6 12.8 5 5.6c-.1-1 .6-1.9 1.6-2.1Z"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linejoin="round"
              />
            </svg>
          )}

          {item.icon === "email" && (
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <rect
                x="3"
                y="5"
                width="18"
                height="14"
                rx="2"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
              />
              <path
                d="m4 7 8 6 8-6"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linejoin="round"
              />
            </svg>
          )}

          {item.icon === "facebook" && (
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path
                d="M14 8h3V4.5c-.5-.1-1.8-.2-3.4-.2-3.3 0-5.6 2-5.6 5.8V13H4v4h4v7h5v-7h3.4l.6-4H13v-2.5C13 9.4 13.3 8 14 8Z"
                fill="currentColor"
              />
            </svg>
          )}

          {item.icon === "instagram" && (
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <rect
                x="3"
                y="3"
                width="18"
                height="18"
                rx="5"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
              />
              <circle
                cx="12"
                cy="12"
                r="4"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
              />
              <circle cx="17.4" cy="6.7" r="1" fill="currentColor" />
            </svg>
          )}

          {item.icon === "x" && (
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path
                d="M5 4h4.2l3.7 5.2L17.4 4H19l-5.4 6.3L20 20h-4.2l-4.1-5.8L6.6 20H5l6-7L5 4Zm3.3 1.5L16.5 18h1.8L10.1 5.5H8.3Z"
                fill="currentColor"
              />
            </svg>
          )}

          <span>{item.label}</span>
        </a>
      ))}
    </aside>
  )
}

<style>
  .floating-socials {
    position: fixed;
    z-index: 60;
    left: 0.75rem;
    bottom: clamp(5.5rem, 18vh, 11rem);
    display: grid;
    gap: 0.55rem;
  }

  .floating-socials__link {
    position: relative;
    display: grid;
    width: 3rem;
    height: 3rem;
    place-items: center;
    border: 1px solid var(--color-border);
    border-radius: 50%;
    background: var(--color-background);
    color: var(--color-text);
    box-shadow: var(--shadow-md);
    transition:
      transform var(--transition),
      background-color var(--transition),
      color var(--transition);
  }

  .floating-socials__link:hover {
    transform: translateY(-3px) scale(1.04);
    background: var(--color-primary);
    color: white;
  }

  .floating-socials__link svg {
    width: 1.35rem;
    height: 1.35rem;
  }

  .floating-socials__link > span {
    position: absolute;
    left: calc(100% + 0.65rem);
    padding: 0.4rem 0.65rem;
    border-radius: 0.45rem;
    background: var(--color-text);
    color: white;
    font-size: 0.8rem;
    font-weight: 700;
    opacity: 0;
    pointer-events: none;
    transform: translateX(-0.35rem);
    transition:
      opacity var(--transition),
      transform var(--transition);
    white-space: nowrap;
  }

  .floating-socials__link:hover > span,
  .floating-socials__link:focus-visible > span {
    opacity: 1;
    transform: translateX(0);
  }
  @media (max-width: 640px) {
    .floating-socials {
      position: fixed;
      z-index: 9999;
      right: 0.75rem;
      bottom: calc(0.75rem + env(safe-area-inset-bottom));
      left: 0.75rem;

      display: flex;
      justify-content: center;
      gap: 0.35rem;

      padding: 0.3rem;

      border: 1px solid var(--color-border);
      border-radius: 1.25rem;

      background: #e2ffcb69;
      box-shadow: var(--shadow-md);
      backdrop-filter: blur(20px);

      pointer-events: auto;
    }

    .floating-socials__link {
      display: flex;
      width: auto;
      min-width: 3.75rem;
      height: 3.5rem;
      flex: 1 1 0;

      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.15rem;

      color: green;
       background-color: rgb(255, 255, 255);
      border-radius: 0.85rem;

      background: transparent;
      box-shadow: none;

      touch-action: manipulation;
      -webkit-tap-highlight-color: transparent;
    }

    .floating-socials__link svg {
      width: 1.3rem;
      height: 1.3rem;
      pointer-events: none;
    }

    .floating-socials__link > span {
      position: static;

      display: block;

      padding: 0;
      border-radius: 0;

      background: transparent;
      color: var(--color-text-muted);

      font-size: 0.68rem;
      font-weight: 700;

      opacity: 1;
      transform: none;

      pointer-events: none;
      white-space: nowrap;
    }

    .floating-socials__link:hover {
      transform: none;
      background: transparent;
      color: var(--color-text);
    }

    .floating-socials__link:active {
      transform: scale(0.92);
      background: color-mix(in srgb, var(--color-primary) 12%, transparent);
      color: var(--color-primary);
    }

    .floating-socials__link:focus-visible {
      outline: 3px solid
        color-mix(in srgb, var(--color-primary) 35%, transparent);
      outline-offset: 2px;
    }


    .floating-socials__link:nth-child(n + 5) {
      display: none;
    }
  }
  
</style>
