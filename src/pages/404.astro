---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="الصفحة غير موجودة"
  description="تعذر العثور على الصفحة المطلوبة."
  noindex={true}
>
  <main class="error-page" id="main-content">
    <div class="container error-content">
      <span>404</span>

      <h1>الصفحة غير موجودة</h1>

      <p>
        ربما تم حذف الصفحة أو تغيير رابطها.
      </p>

      <a href="/">العودة إلى الصفحة الرئيسية</a>
    </div>
  </main>
</BaseLayout>

<style>
  .error-page {
    display: grid;
    min-height: 70svh;
    place-items: center;
    padding-block: 4rem;
    text-align: center;
  }

  .error-content {
    max-width: 700px;
  }

  .error-content > span {
    color: var(--color-primary);
    font-size: clamp(4rem, 18vw, 10rem);
    font-weight: 900;
    line-height: 1;
  }

  h1 {
    margin-block: 1rem;
    font-size: clamp(2rem, 6vw, 3.5rem);
  }

  p {
    color: var(--color-text-muted);
  }

  a {
    display: inline-flex;
    min-height: 48px;
    align-items: center;
    justify-content: center;
    margin-top: 1.5rem;
    padding-inline: 1.25rem;
    border-radius: var(--radius-md);
    background: var(--color-primary);
    color: white;
    font-weight: 700;
  }
</style>