---
interface ServiceItem {
  id: string;

  data: {
    title: string;
    description: string;
    shortDescription?: string;
    image?: string;
    imageAlt?: string;
  };
}

interface Props {
  services: ServiceItem[];
}

const { services } = Astro.props;
---

{
  services.length > 0 && (
    <section class="related-services">
      <header>
        <span>خدمات أخرى</span>
        <h2>قد تهمك هذه الخدمات</h2>
      </header>

      <div class="related-services__grid">
        {services.map((service) => (
          <article>
            {service.data.image && (
              <a
                class="related-services__media"
                href={`/services/${service.id}/`}
              >
                <img
                  src={service.data.image}
                  alt={
                    service.data.imageAlt ||
                    service.data.title
                  }
                  width="700"
                  height="450"
                  loading="lazy"
                  decoding="async"
                />
              </a>
            )}

            <div class="related-services__content">
              <h3>
                <a href={`/services/${service.id}/`}>
                  {service.data.title}
                </a>
              </h3>

              <p>
                {service.data.shortDescription ||
                  service.data.description}
              </p>

              <a
                class="related-services__link"
                href={`/services/${service.id}/`}
              >
                تفاصيل الخدمة
                <span aria-hidden="true">←</span>
              </a>
            </div>
          </article>
        ))}
      </div>
    </section>
  )
}

<style>
  .related-services {
    margin-top: 4rem;
  }

  .related-services header {
    margin-bottom: 1.5rem;
  }

  .related-services header > span {
    color: var(--color-primary);
    font-weight: 800;
  }

  .related-services h2 {
    margin-block: 0.5rem 0;
    font-size: clamp(1.7rem, 4vw, 2.5rem);
  }

  .related-services__grid {
    display: grid;
    gap: 1rem;
  }

  .related-services article {
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    transition:
      transform var(--transition),
      box-shadow var(--transition);
  }

  .related-services article:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }

  .related-services__media {
    display: block;
    overflow: hidden;
    aspect-ratio: 16 / 10;
  }

  .related-services__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 350ms ease;
  }

  .related-services article:hover img {
    transform: scale(1.04);
  }

  .related-services__content {
    padding: 1.25rem;
  }

  .related-services h3 {
    margin-bottom: 0.65rem;
  }

  .related-services p {
    color: var(--color-text-muted);
  }

  .related-services__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-primary);
    font-weight: 800;
  }

  @media (min-width: 700px) {
    .related-services__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>