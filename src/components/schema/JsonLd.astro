---
interface Props {
  data: Record<string, unknown>;
}

const { data } = Astro.props;

/**
 * استبدال علامة < يمنع احتمال تفسير محتوى JSON
 * كوسم HTML عند وجود نصوص ديناميكية.
 */
const jsonLd = JSON.stringify(data).replace(
  /</g,
  "\\u003c"
);
---

<script
  type="application/ld+json"
  set:html={jsonLd}
/>