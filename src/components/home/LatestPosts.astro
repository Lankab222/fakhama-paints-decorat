---
interface PostItem {
  id: string;

  data: {
    title: string;
    description: string;
    publishDate: Date;
    image?: string;
    imageAlt?: string;
    category: string;
    author: string;
  };
}

interface Props {
  posts: PostItem[];
}

const { posts } = Astro.props;

const formatDate = (date: Date) =>
  date.toLocaleDateString("ar-SA", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
---

{
  posts.length > 0 && (
    <section class="section latest-posts">
      <div class="container">
        <header class="section-header">
          <div>
            <h1 class="eyebrow">احدث اعمالنا</h1>
            <h2>أحدث ماقمنا ونقوم بتنفيذه من اعمال الدهانات والديكورات </h2>
          </div>

          <a class="view-all" href="/blog/">
            جميع المنشورات
            <span aria-hidden="true">←</span>
          </a>
        </header>

        <div class="posts-grid">
          {posts.map((post) => (
            <article class="post-card">
              {post.data.image && (
                <a
                  class="post-card__media"
                  href={`/blog/${post.id}/`}
                >
                  <img
                    src={post.data.image}
                    alt={post.data.imageAlt || post.data.title}
                    width="800"
                    height="500"
                    loading="lazy"
                    decoding="async"
                  />
                </a>
              )}

              <div class="post-card__content">
                <div class="post-card__meta">
                  <span>{post.data.category}</span>

                  <time
                    datetime={post.data.publishDate.toISOString()}
                  >
                    {formatDate(post.data.publishDate)}
                  </time>
                </div>

                <h3>
                  <a href={`/blog/${post.id}/`}>
                    {post.data.title}
                  </a>
                </h3>

                <p>{post.data.description}</p>

                <a
                  class="post-card__link"
                  href={`/blog/${post.id}/`}
                >
                  قراءة المقال
                  <span aria-hidden="true">←</span>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )
}

<style>
  .latest-posts {
    background: var(--color-surface);
  }

  .section-header {
    display: grid;
    gap: 1.25rem;
    margin-bottom: 2.25rem;
  }
h1{
  margin: 0;
}
  .eyebrow {
    color: var(--color-primary);
    font-weight: bold;
    font-size: 3rem;
    text-align: center;
  }

  .section-header h2 {
    margin-block: 0.55rem 0;
    font-size: clamp(2rem, 5vw, 3.5rem);
  }

  .view-all {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    align-self: end;
    justify-self: start;
    color: var(--color-primary);
    font-weight: 800;
  }

  .posts-grid {
    display: grid;
    gap: 1.25rem;
  }

  .post-card {
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-background);
    box-shadow: var(--shadow-sm);
    transition:
      transform var(--transition),
      box-shadow var(--transition);
  }

  .post-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }

  .post-card__media {
    display: block;
    overflow: hidden;
    aspect-ratio: 16 / 10;
  }

  .post-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 350ms ease;
  }
h2{
  text-align: center;
  font-size: 2rem;
  font-weight: bold;
}
  .post-card:hover .post-card__media img {
    transform: scale(1.04);
  }

  .post-card__content {
    padding: 1.5rem;
  }

  .post-card__meta {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.5rem 1rem;
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }

  .post-card__meta span {
    color: var(--color-primary);
    font-weight: 800;
  }

  .post-card h3 {
    margin-block: 0.75rem;
    font-size: 1.35rem;
    line-height: 1.45;
  }

  .post-card p {
    display: -webkit-box;
    overflow: hidden;
    color: var(--color-text-muted);
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .post-card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.75rem;
    color: var(--color-primary);
    font-weight: 800;
  }

  @media (min-width: 768px) {
    .section-header {
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: end;
    }

    .view-all {
      justify-self: end;
    }

    .posts-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1100px) {
    .posts-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>