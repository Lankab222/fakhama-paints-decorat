---
import JsonLd from "./JsonLd.astro";

interface Props {
  siteName: string;
  siteUrl: string;
  title: string;
  description: string;

  logo?: string;
  image?: string;

  phone?: string;
  email?: string;
  address?: string;

  pageType?: "WebPage" | "AboutPage" | "ContactPage";
}

const {
  siteName,
  siteUrl,
  title,
  description,
  logo = "/favicon.svg",
  image = "/og-default.jpg",
  phone,
  email,
  address,
  pageType = "WebPage",
} = Astro.props;

const baseUrl = siteUrl.replace(/\/$/, "");

const currentPageUrl = new URL(Astro.url.pathname, `${baseUrl}/`).toString();

const organizationId = `${baseUrl}/#organization`;
const websiteId = `${baseUrl}/#website`;
const webpageId = `${currentPageUrl}#webpage`;

const schema = {
  "@context": "https://schema.org",

  "@graph": [
    {
      "@type": ["LocalBusiness", "HomeAndConstructionBusiness"],
      "@id": organizationId,
      name: siteName,
      url: `${baseUrl}/`,
      telephone: phone,
      image: new URL(image, `${baseUrl}/`).toString(),
      logo: {
        "@type": "ImageObject",
        url: new URL(logo, `${baseUrl}/`).toString(),
      },
      address: {
    "@type": "PostalAddress",
    addressLocality: "مكة المكرمة",
    addressRegion: "مكة المكرمة",
    addressCountry: "SA",
  },
    },

    {
      "@type": "WebSite",
      "@id": websiteId,
      url: `${baseUrl}/`,
      name: siteName,
      description,
      inLanguage: "ar",
      publisher: {
        "@id": organizationId,
      },
    },

    {
      "@type": pageType,
      "@id": webpageId,
      url: currentPageUrl,
      name: title,
      description,
      inLanguage: "ar",
      isPartOf: {
        "@id": websiteId,
      },
      about: {
        "@id": organizationId,
      },
      primaryImageOfPage: {
        "@type": "ImageObject",
        url: new URL(image, `${baseUrl}/`).toString(),
      },
    },
  ],
};
---

<JsonLd data={schema} />
