---
import JsonLd from "./JsonLd.astro";

type PageType = "WebPage" | "AboutPage" | "ContactPage" | "CollectionPage";

interface PostalAddress {
  addressLocality?: string;
  addressRegion?: string;
  postalCode?: string;
  addressCountry?: string;
}

interface BreadcrumbItem {
  name: string;
  url: string;
}
interface CollectionItem {
  name: string;
  url: string;
  description?: string;
  image?: string;
}
interface ServiceItem {
  name: string;
  url: string;
  description?: string;
  image?: string;
}
interface Props {
  siteName: string;

  /**
   * يمكن تمريره يدويًا، أو الاعتماد على site
   * داخل astro.config.mjs
   */
  siteUrl?: string;

  /**
   * وصف ثابت للموقع والنشاط
   */
  siteDescription: string;

  /**
   * بيانات الصفحة الحالية
   */
  title: string;
  description: string;

  /**
   * رابط Canonical اختياري.
   * يقبل رابطًا نسبيًا أو كاملًا.
   */
  canonicalUrl?: string;

  /**
   * بيانات النشاط
   */
  logo?: string;
  businessImage?: string;
  phone?: string;
  email?: string;
  address?: PostalAddress;
  areaServed?: string[];
  sameAs?: string[];
  serviceItems?: ServiceItem[];
  /**
   * بيانات الصفحة الحالية
   */
  pageImage?: string;
  pageType?: PageType;
  collectionItems?: CollectionItem[];
  /**
   * مسار التنقل للصفحات الداخلية
   */
  breadcrumbs?: BreadcrumbItem[];
}

const {
  siteName,
  siteUrl,
  siteDescription,

  title,
  description,
  canonicalUrl,

  logo = "/uploads/logo2.webp",
  businessImage = "/uploads/hero-image.webp",
  serviceItems = [],
  phone,
  email,
  address,
  areaServed = [],
  sameAs = [],
  collectionItems = [],
  pageImage,
  pageType = "WebPage",
  breadcrumbs = [],
} = Astro.props;

const baseUrl = (siteUrl ?? Astro.site?.toString() ?? "").replace(/\/+$/, "");

if (!baseUrl) {
  throw new Error("يجب تحديد siteUrl أو إضافة site داخل astro.config.mjs");
}

/**
 * تحويل أي رابط نسبي إلى رابط كامل
 */
const toAbsoluteUrl = (value: string) =>
  new URL(value, `${baseUrl}/`).toString();

/**
 * رابط الصفحة الحالي بدون query parameters
 */
const currentPageUrl = canonicalUrl
  ? toAbsoluteUrl(canonicalUrl)
  : new URL(Astro.url.pathname, `${baseUrl}/`).toString();

const homeUrl = `${baseUrl}/`;

const organizationId = `${homeUrl}#organization`;
const websiteId = `${homeUrl}#website`;
const logoId = `${homeUrl}#logo`;
const businessImageId = `${homeUrl}#business-image`;

const webpageId = `${currentPageUrl}#webpage`;
const breadcrumbId = `${currentPageUrl}#breadcrumb`;
const itemListId = `${currentPageUrl}#itemlist`;
const logoUrl = toAbsoluteUrl(logo);
const businessImageUrl = toAbsoluteUrl(businessImage);
const servicesListId = `${currentPageUrl}#services-list`;
const pageImageUrl = toAbsoluteUrl(pageImage ?? businessImage);

/**
 * إذا كانت صورة الصفحة هي نفسها صورة النشاط،
 * نستخدم نفس العقدة بدل إنشاء صورة مكررة.
 */
const primaryImageId =
  pageImageUrl === businessImageUrl
    ? businessImageId
    : `${currentPageUrl}#primaryimage`;

const organizationNode = {
  "@type": "HomeAndConstructionBusiness",
  "@id": organizationId,

  name: siteName,
  url: homeUrl,
  description: siteDescription,

  logo: {
    "@id": logoId,
  },

  image: {
    "@id": businessImageId,
  },

  ...(phone && {
    telephone: phone,

    contactPoint: {
      "@type": "ContactPoint",
      telephone: phone,
      contactType: "customer service",
      areaServed: "SA",
      availableLanguage: ["ar"],
    },
  }),

  ...(email && {
    email,
  }),

  // ...(address && {
  //   address: {
  //     "@type": "PostalAddress",
  //     ...address,
  //   },
  // }),
  ...(address && {
    address: {
      "@type": "PostalAddress",
      addressLocality: address.addressLocality,
      addressRegion: address.addressRegion,
      postalCode: address.postalCode,
      addressCountry: address.addressCountry,
    },
  }),

  ...(areaServed.length > 0 && {
    areaServed: areaServed.map((city) => ({
      "@type": "City",
      name: city,
    })),
  }),

  ...(sameAs.length > 0 && {
    sameAs,
  }),
};

const logoNode = {
  "@type": "ImageObject",
  "@id": logoId,

  url: logoUrl,
  contentUrl: logoUrl,
  caption: `شعار ${siteName}`,
  inLanguage: "ar-SA",
};

const businessImageNode = {
  "@type": "ImageObject",
  "@id": businessImageId,

  url: businessImageUrl,
  contentUrl: businessImageUrl,
  caption: siteName,
  inLanguage: "ar-SA",
};

const websiteNode = {
  "@type": "WebSite",
  "@id": websiteId,

  url: homeUrl,
  name: siteName,
  description: siteDescription,
  inLanguage: "ar-SA",

  publisher: {
    "@id": organizationId,
  },
};

const webpageNode = {
  "@type": pageType,
  "@id": webpageId,

  url: currentPageUrl,
  name: title,
  description,
  inLanguage: "ar-SA",

  isPartOf: {
    "@id": websiteId,
  },

  about: {
    "@id": organizationId,
  },

  primaryImageOfPage: {
    "@id": primaryImageId,
  },

  ...(breadcrumbs.length > 0 && {
    breadcrumb: {
      "@id": breadcrumbId,
    },
  }),
  ...(collectionItems.length > 0 && {
    mainEntity: {
      "@id": itemListId,
    },
  }),
  ...(pageType === "AboutPage" || pageType === "ContactPage"
    ? {
        mainEntity: {
          "@id": organizationId,
        },
      }
    : {}),
  ...(serviceItems.length > 0 && {
    mainEntity: {
      "@id": servicesListId,
    },
  }),
};

const primaryImageNode =
  pageImageUrl !== businessImageUrl
    ? {
        "@type": "ImageObject",
        "@id": primaryImageId,

        url: pageImageUrl,
        contentUrl: pageImageUrl,
        caption: title,
        inLanguage: "ar-SA",
      }
    : null;

const breadcrumbNode =
  breadcrumbs.length > 0
    ? {
        "@type": "BreadcrumbList",
        "@id": breadcrumbId,

        itemListElement: breadcrumbs.map((item, index) => ({
          "@type": "ListItem",
          position: index + 1,
          name: item.name,
          item: toAbsoluteUrl(item.url),
        })),
      }
    : null;

const collectionItemListNode =
  collectionItems.length > 0
    ? {
        "@type": "ItemList",
        "@id": itemListId,

        name: `قائمة ${title}`,

        numberOfItems: collectionItems.length,

        itemListOrder: "https://schema.org/ItemListOrderDescending",

        itemListElement: collectionItems.map((item, index) => {
          const articleUrl = toAbsoluteUrl(item.url);

          return {
            "@type": "ListItem",
            position: index + 1,

            item: {
              "@type": "BlogPosting",
              "@id": `${articleUrl}#article`,

              url: articleUrl,
              headline: item.name,

              ...(item.description && {
                description: item.description,
              }),

              ...(item.image && {
                image: toAbsoluteUrl(item.image),
              }),
            },
          };
        }),
      }
    : null;
const servicesItemListNode =
  serviceItems.length > 0
    ? {
        "@type": "ItemList",
        "@id": servicesListId,

        name: `قائمة خدمات ${siteName}`,

        numberOfItems: serviceItems.length,

        itemListOrder: "https://schema.org/ItemListOrderAscending",

        itemListElement: serviceItems.map((service, index) => {
          const serviceUrl = toAbsoluteUrl(service.url);

          return {
            "@type": "ListItem",
            position: index + 1,

            item: {
              "@type": "Service",
              "@id": `${serviceUrl}#service`,

              name: service.name,
              url: serviceUrl,

              ...(service.description && {
                description: service.description,
              }),

              ...(service.image && {
                image: toAbsoluteUrl(service.image),
              }),

              provider: {
                "@id": organizationId,
              },

              areaServed: {
                "@type": "City",
                name: "مكة المكرمة",
              },
            },
          };
        }),
      }
    : null;
const schema = {
  "@context": "https://schema.org",

  "@graph": [
    organizationNode,
    logoNode,
    businessImageNode,
    websiteNode,

    ...(primaryImageNode ? [primaryImageNode] : []),

    webpageNode,

    ...(breadcrumbNode ? [breadcrumbNode] : []),
    ...(collectionItemListNode ? [collectionItemListNode] : []),
    ...(servicesItemListNode ? [servicesItemListNode] : []),
  ],
};
---

<JsonLd data={schema} />
