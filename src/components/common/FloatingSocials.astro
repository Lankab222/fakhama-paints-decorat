---
interface Props {
  phone?: string;
  whatsapp?: string;
  email?: string;
  instagram?: string;
  whatsappMessage?: string;
}

const {
  phone,
  whatsapp,
  email,
  instagram,
  whatsappMessage = "مرحبًا، أريد الاستفسار عن خدماتكم",
} = Astro.props;

const cleanPhone = phone?.replace(/[^\d+]/g, "");
const cleanWhatsapp = whatsapp?.replace(/\D/g, "");

const whatsappUrl = cleanWhatsapp
  ? `https://wa.me/${cleanWhatsapp}?text=${encodeURIComponent(whatsappMessage)}`
  : undefined;

const items = [
  {
    label: "واتساب",
    href: whatsappUrl,
    className: "whatsapp",
    icon: "whatsapp",
    external: true,
    action: "whatsapp",
  },
  {
    label: "اتصال",
    href: cleanPhone ? `tel:${cleanPhone}` : undefined,
    className: "phone",
    icon: "phone",
    external: false,
    action: "phone",
  },
  {
    label: "إنستغرام",
    href: instagram || undefined,
    className: "instagram",
    icon: "instagram",
    external: true,
    action: "instagram",
  },
  {
    label: "البريد",
    href: email ? `mailto:${email}` : undefined,
    className: "email",
    icon: "email",
    external: false,
    action: "email",
  },
].filter(
  (
    item,
  ): item is typeof item & {
    href: string;
  } => Boolean(item.href),
);
---

{
  items.length > 0 && (
    <aside class="floating-socials" aria-label="روابط التواصل السريعة">
      {items.map((item) => (
        <a
          class={`floating-socials__link ${item.className}`}
          href={item.href}
          aria-label={item.label}
          title={item.label}
          target={item.external ? "_blank" : undefined}
          rel={item.external ? "noopener noreferrer" : undefined}
          data-contact-action={item.action}
        >
          {item.icon === "whatsapp" && (
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path
                d="M20.5 11.8a8.4 8.4 0 0 1-12.4 7.4L3 20.5l1.4-4.9a8.4 8.4 0 1 1 16.1-3.8Z"
                fill="none"
                stroke="currentColor"
                stroke-width="1.9"
                stroke-linejoin="round"
              />
              <path
                d="M8.2 7.7c.3-.5.6-.5.9-.5h.4c.2 0 .4.1.5.4l.8 1.9c.1.3 0 .5-.1.7l-.6.8c-.2.2-.2.4 0 .7.5.9 1.2 1.6 2.1 2.1.3.2.5.2.7 0l.9-1c.2-.2.4-.2.7-.1l1.9.9c.3.1.4.3.4.5 0 .5-.2 1.4-.7 1.9-.5.5-1.3.8-2.1.7-1.1-.1-2.5-.6-4.2-2.1-2-1.8-3.2-4-3.3-5.3-.1-.7.2-1.2.7-1.6Z"
                fill="currentColor"
              />
            </svg>
          )}

          {item.icon === "phone" && (
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path
                d="M6.6 3.5 9 3c.6-.1 1.1.2 1.3.8l1.1 3.1c.2.5 0 1-.4 1.3L9.5 9.4a14 14 0 0 0 5.1 5.1l1.2-1.5c.3-.4.8-.6 1.3-.4l3.1 1.1c.6.2.9.7.8 1.3l-.5 2.4c-.2 1-1.1 1.7-2.1 1.6C11.2 18.4 5.6 12.8 5 5.6c-.1-1 .6-1.9 1.6-2.1Z"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linejoin="round"
              />
            </svg>
          )}

          {item.icon === "instagram" && (
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <rect
                x="3"
                y="3"
                width="18"
                height="18"
                rx="5"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
              />
              <circle
                cx="12"
                cy="12"
                r="4"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
              />
              <circle cx="17.4" cy="6.7" r="1" fill="currentColor" />
            </svg>
          )}

          {item.icon === "email" && (
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <rect
                x="3"
                y="5"
                width="18"
                height="14"
                rx="2"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
              />
              <path
                d="m4 7 8 6 8-6"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linejoin="round"
              />
            </svg>
          )}

          <span>{item.label}</span>
        </a>
      ))}
    </aside>
  )
}

<style>
  .floating-socials {
    position: fixed;
    z-index: 9999;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .floating-socials__link {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.4rem;
    height: 3.4rem;
    border-radius: 999px;
    text-decoration: none;
    color: #fff;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.16);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      opacity 0.2s ease;
  }

  .floating-socials__link:hover {
    transform: translateX(4px) scale(1.05);
    box-shadow: 0 14px 30px rgba(0, 0, 0, 0.2);
  }

  .floating-socials__link:focus-visible {
    outline: 3px solid rgba(59, 130, 246, 0.3);
    outline-offset: 3px;
  }

  .floating-socials__link svg {
    width: 1.35rem;
    height: 1.35rem;
  }

  .floating-socials__link > span {
    position: absolute;
    left: calc(100% + 0.7rem);
    top: 80%;
    transform: translateY(-50%) translateX(-8px);
    background: #111827;
    color: #fff;
    padding: 0.45rem 0.7rem;
    border-radius: 0.6rem;
    font-size: 0.82rem;
    font-weight: 700;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
  }

  .floating-socials__link:hover > span,
  .floating-socials__link:focus-visible > span {
    opacity: 1;
    transform: translateY(-50%) translateX(0);
  }

  .floating-socials__link.whatsapp {
    background: linear-gradient(135deg, #25d366, #16a34a);
  }

  .floating-socials__link.phone {
    background: linear-gradient(135deg, #2563eb, #1d4ed8);
  }

  .floating-socials__link.instagram {
    background: linear-gradient(135deg, #e1306c, #f77737);
  }

  .floating-socials__link.email {
    background: linear-gradient(135deg, #6b7280, #374151);
  }

  @media (max-width: 640px) {
    .floating-socials {
      left: 0.6rem;
      top: 80%;
      bottom: auto;
      transform: translateY(-50%);
      gap: 0.55rem;
    }

    .floating-socials__link {
      width: 3rem;
      height: 3rem;
    }

    .floating-socials__link svg {
      width: 1.2rem;
      height: 1.2rem;
    }

    .floating-socials__link > span {
      display: none;
    }
  }
</style>