---
interface ServiceItem {
  id: string;

  data: {
    title: string;
    description: string;
    shortDescription?: string;
    image?: string;
    imageAlt?: string;
    features: string[];
  };
}

interface Props {
  services: ServiceItem[];
}

const { services } = Astro.props;
---

{
  services.length > 0 && (
    <section class="section featured-services">
      <div class="container">
        <header class="section-header">
          <div>
            <h1 class="eyebrow">خدماتنا</h1>
            <h2>حلول مصممة لتلبية احتياجات مشروعك</h2>
          </div>

          <a class="view-all" href="/services/">
            عرض جميع الخدمات
            <span aria-hidden="true">←</span>
          </a>
        </header>

        <div class="services-grid">
          {services.map((service, index) => (
            <article class="service-card">
              {service.data.image && (
                <a
                  class="service-card__media"
                  href={`/services/${service.id}/`}
                  aria-label={`عرض خدمة ${service.data.title}`}
                >
                  <img
                    src={service.data.image}
                    alt={
                      service.data.imageAlt ||
                      service.data.title
                    }
                    width="800"
                    height="520"
                    loading={index === 0 ? "eager" : "lazy"}
                    decoding="async"
                  />
                </a>
              )}

              <div class="service-card__content">
                <span class="service-card__number">
                  {String(index + 1).padStart(2, "0")}
                </span>

                <h3>
                  <a href={`/services/${service.id}/`}>
                    {service.data.title}
                  </a>
                </h3>

                <p>
                  {service.data.shortDescription ||
                    service.data.description}
                </p>

                {service.data.features.length > 0 && (
                  <ul>
                    {service.data.features
                      .slice(0, 3)
                      .map((feature) => (
                        <li>
                          <span aria-hidden="true">✓</span>
                          {feature}
                        </li>
                      ))}
                  </ul>
                )}

                <a
                  class="service-card__link"
                  href={`/services/${service.id}/`}
                >
                  معرفة المزيد
                  <span aria-hidden="true">←</span>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )
}

<style>
  .featured-services {
    background: var(--color-background);
  }

  .section-header {
    display: grid;
    gap: 1.25rem;
    margin-bottom: 2.25rem;
  }

  .section-header > div {
    max-width: 760px;
  }

  .eyebrow {
    color: var(--color-primary);
    font-weight: bold;
    font-size: 3rem;
    text-align: center;
  }

  .section-header h2 {
    margin-block: 0.55rem 0;
    font-size: clamp(1.9rem, 5vw, 3.4rem);
    line-height: 1.25;
  }

  .view-all {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    justify-self: start;
    color: var(--color-primary);
    font-weight: 800;
  }

  .services-grid {
    display: grid;
    gap: 1.25rem;
  }

  .service-card {
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    box-shadow: var(--shadow-sm);
    transition:
      transform var(--transition),
      box-shadow var(--transition);
  }

  .service-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }

  .service-card__media {
    display: block;
    overflow: hidden;
    aspect-ratio: 16 / 10;
    background: var(--color-secondary);
  }
 h1{
      margin: 0;
 }
  .service-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 350ms ease;
  }

  .service-card:hover .service-card__media img {
    transform: scale(1.04);
  }

  .service-card__content {
    position: relative;
    padding: 1.5rem;
  }

  .service-card__number {
    display: inline-grid;
    width: 2.4rem;
    height: 2.4rem;
    place-items: center;
    margin-bottom: 1rem;
    border-radius: 50%;
    background:
      color-mix(in srgb, var(--color-primary) 10%, transparent);
    color: var(--color-primary);
    font-size: 0.85rem;
    font-weight: 900;
  }

  .service-card h3 {
    margin-bottom: 0.7rem;
    font-size: 1.35rem;
  }

  .service-card p {
    color: var(--color-text-muted);
  }

  .service-card ul {
    display: grid;
    gap: 0.55rem;
    margin-block: 1.25rem;
    padding: 0;
    list-style: none;
  }

  .service-card li {
    display: flex;
    gap: 0.5rem;
    color: var(--color-text-muted);
    font-size: 0.93rem;
  }

  .service-card li span {
    color: var(--color-primary);
    font-weight: 900;
  }

  .service-card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-primary);
    font-weight: 800;
  }

  @media (min-width: 768px) {
    .section-header {
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: end;
    }

    .view-all {
      justify-self: end;
    }

    .services-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1100px) {
    .services-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>