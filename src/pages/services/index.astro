---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/common/PageHero.astro";
import SiteSchema from "../../components/schema/SiteSchema.astro";
const services = (await getCollection("services"))
  .filter((service) => !service.data.draft)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="خدمات الدهانات والديكورات التي نقدمها"
  description="تعرف على خدمات دهانات وديكورات الفخامة في الدهانات الداخلية والخارجية، والديكورات، والعوازل، والترميمات بمكة المكرمة."
>
<Fragment slot="head">
    <SiteSchema
  siteName="دهانات وديكورات الفخامة"
  siteUrl="https://alfakhama.site"
  siteDescription="تنفيذ أعمال الدهانات والديكورات والعوازل والترميمات في مكة المكرمة."

  title="خدماتنا  | دهانات وديكورات الفخامة"
  description="تعرف على خبرة دهانات وديكورات الفخامة وخدماتنا في مكة المكرمة."

  phone="+966543441970"

  address={{
    addressLocality: "مكة المكرمة",
    addressRegion: "مكة المكرمة",
    addressCountry: "SA",
    streetAddress: "العزيزية",
    postalCode: "12455",
  }}

  pageType="CollectionPage"

  breadcrumbs={[
    {
      name: "الرئيسية",
      url: "/",
    },
    {
      name: "خدماتنا",
      url: "/services/",
    },
  ]}
/>
     
     
  </Fragment>
  <main id="main-content">
    <PageHero
  eyebrow="خدماتنا"
  title="خدمات الدهانات والديكورات التي نقدمها"
  description="تعرف على خدمات دهانات وديكورات الفخامة في الدهانات الداخلية والخارجية، والديكورات، والعوازل، والترميمات بمكة المكرمة."
/>

    <section class="section">
      <div class="container">
        {
          services.length > 0 ? (
            <div class="services-grid">
              {services.map((service) => (
                <article class="service-card">
                  {service.data.image && (
                    <a
                      href={`/services/${service.id}/`}
                      class="service-card__image-link"
                    >
                      <img
                        class="service-card__image"
                        src={service.data.image}
                        alt={service.data.imageAlt || service.data.title}
                        width="800"
                        height="500"
                        loading="lazy"
                        decoding="async"
                      />
                    </a>
                  )}

                  <div class="service-card__content">
                    <h2>
                      <a href={`/services/${service.id}/`}>
                        {service.data.title}
                      </a>
                    </h2>

                    <p>
                      {service.data.shortDescription ||
                        service.data.description}
                    </p>

                    {service.data.features.length > 0 && (
                      <ul>
                        {service.data.features.slice(0, 4).map((feature) => (
                          <li>{feature}</li>
                        ))}
                      </ul>
                    )}

                    <a
                      class="service-card__link"
                      href={`/services/${service.id}/`}
                    >
                      تفاصيل الخدمة
                    </a>
                  </div>
                </article>
              ))}
            </div>
          ) : (
            <p>لا توجد خدمات منشورة حاليًا.</p>
          )
        }
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  
.service-card,
.project-card,
.post-card {
  transition:
    transform var(--transition),
    box-shadow var(--transition),
    border-color var(--transition);
}

.service-card:hover,
.project-card:hover,
.post-card:hover {
  transform: translateY(-4px);
  border-color:
    color-mix(
      in srgb,
      var(--color-primary) 28%,
      var(--color-border)
    );
  box-shadow: var(--shadow-md);
}
  .eyebrow {
    color: var(--color-primary);
    font-weight: 700;
  }



  .services-grid {
    display: grid;
    gap: 1.25rem;
  }

  .service-card {
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    box-shadow: var(--shadow-sm);
  }

  .service-card__image-link {
    display: block;
    overflow: hidden;
    aspect-ratio: 16 / 10;
    background: var(--color-secondary);
  }

  .service-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition);
  }

  .service-card:hover .service-card__image {
    transform: scale(1.03);
  }

  .service-card__content {
    padding: 1.5rem;
  }

  .service-card h2 {
    margin-bottom: 0.75rem;
    font-size: 1.4rem;
  }

  .service-card p {
    color: var(--color-text-muted);
  }

  .service-card ul {
    margin-block: 1rem;
    padding-inline-start: 1.25rem;
  }

  .service-card li {
    margin-bottom: 0.4rem;
  }

  .service-card__link {
    color: var(--color-primary);
    font-weight: 700;
  }

  @media (min-width: 768px) {
    .services-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1100px) {
    .services-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>