---
interface Props {
  title: string;
  description: string;

  canonical?: string;
  image?: string;

  type?: "website" | "article";
  locale?: string;

  noindex?: boolean;

  publishedTime?: Date | string;
  modifiedTime?: Date | string;

  author?: string;
}

const {
  title,
  description,
  canonical,
  image = "/og-default.jpg",
  type = "website",
  locale = "ar_SA",
  noindex = false,
  publishedTime,
  modifiedTime,
  author,
} = Astro.props;

const siteUrl = Astro.site ?? new URL("https://example.com");

const canonicalUrl = canonical
  ? new URL(canonical, siteUrl)
  : new URL(Astro.url.pathname, siteUrl);

const imageUrl = new URL(image, siteUrl);

const robotsContent = noindex
  ? "noindex, nofollow"
  : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1";

const formatDate = (date?: Date | string) => {
  if (!date) return undefined;

  return date instanceof Date
    ? date.toISOString()
    : new Date(date).toISOString();
};

const published = formatDate(publishedTime);
const modified = formatDate(modifiedTime);
---

<title>{title}</title>

<meta name="description" content={description} />
<meta name="robots" content={robotsContent} />

<link rel="canonical" href={canonicalUrl.toString()} />

<meta property="og:locale" content={locale} />
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalUrl.toString()} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageUrl.toString()} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={title} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl.toString()} />

{
  type === "article" && published && (
    <meta property="article:published_time" content={published} />
  )
}

{
  type === "article" && modified && (
    <meta property="article:modified_time" content={modified} />
  )
}

{
  type === "article" && author && (
    <meta property="article:author" content={author} />
  )
}