---
interface Props {
  siteName: string;
  footerText: string;

  description?: string;
  logo?: string;

  phone?: string;
  whatsapp?: string;
  email?: string;
  address?: string;

  facebook?: string;
  instagram?: string;
  x?: string;
  youtube?: string;
}

const {
  siteName,
  footerText,
  description,
  logo,

  phone,
  whatsapp,
  email,
  address,

  facebook,
  instagram,
  x,
  youtube,
} = Astro.props;

const year = new Date().getFullYear();

const cleanWhatsapp = whatsapp?.replace(/\D/g, "");

const socialLinks = [
  {
    label: "فيسبوك",
    href: facebook,
  },
  {
    label: "إنستغرام",
    href: instagram,
  },
  {
    label: "منصة X",
    href: x,
  },
  {
    label: "يوتيوب",
    href: youtube,
  },
].filter(
  (
    item,
  ): item is {
    label: string;
    href: string;
  } => Boolean(item.href),
);
---

<footer class="site-footer">
  <div class="container footer-grid">
    <section class="footer-brand">
      <a class="footer-logo" href="/" aria-label={siteName}>
        {
          logo && (
            <img
              src={logo}
              alt={siteName}
              width="52"
              height="52"
              loading="lazy"
            />
          )
        }

        <strong>{siteName}</strong>
      </a>

      {
        description && (
          <p>{description}</p>
        )
      }

      {
        socialLinks.length > 0 && (
          <div class="social-links">
            {socialLinks.map((item) => (
              <a
                href={item.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={item.label}
              >
                {item.label}
              </a>
            ))}
          </div>
        )
      }
    </section>

    <section>
      <h2>روابط سريعة</h2>

      <nav class="footer-links" aria-label="روابط الفوتر">
        <a href="/">الرئيسية</a>
        <a href="/about/">من نحن</a>
        <a href="/services/">الخدمات</a>
        <a href="/projects/">المشاريع</a>
        <a href="/blog/">المنشورات</a>
        <a href="/contact/">اتصل بنا</a>
      </nav>
    </section>

    <section>
      <h2>خدماتنا</h2>

      <nav class="footer-links" aria-label="روابط الخدمات">
        <a href="/services/">خدماتنا</a>
        <a href="/projects/">المشاريع</a>
        <a href="/blog/">اخر الاعمال</a>
        <a href="/contact/">تواصل معنا </a>
      </nav>
    </section>

    <section>
      <h2>تواصل معنا</h2>

      <div class="contact-list">
        {
          phone && (
            <a href={`tel:${phone}`}>
              <strong>الهاتف</strong>
              <span>{phone}</span>
            </a>
          )
        }

        {
          cleanWhatsapp && (
            <a
              href={`https://wa.me/${cleanWhatsapp}`}
              target="_blank"
              rel="noopener noreferrer"
            >
              <strong>واتساب</strong>
              <span>{whatsapp}</span>
            </a>
          )
        }

        {
          email && (
            <a href={`mailto:${email}`}>
              <strong>البريد</strong>
              <span>{email}</span>
            </a>
          )
        }

        {
          address && (
            <div>
              <strong>العنوان</strong>
              <span>{address}</span>
            </div>
          )
        }
      </div>
    </section>
  </div>

  <div class="container footer-bottom">
    <p>
      {footerText} © {year} {siteName}
    </p>

    <nav aria-label="الصفحات القانونية">
      <a href="/privacy/">سياسة الخصوصية</a>
      <a href="/terms/">شروط الاستخدام</a>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 3rem;
    padding-block: 4rem 1.5rem;
    border-top: 1px solid var(--color-border);
    background: var(--color-primary-dark);
  }

  .footer-grid {
    display: grid;
    gap: 2.5rem;
  }

  .footer-brand {
    max-width: 460px;
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 1rem;
    font-size: 1.15rem;
  }

  .footer-logo img {
    width: 48px;
    height: 48px;
    object-fit: contain;
  }

  .footer-brand p {
    color: var(--color-text-muted);
  }

  .site-footer h2 {
    margin-bottom: 1rem;
    font-size: 1.05rem;
  }

  .footer-links,
  .contact-list {
    display: grid;
    gap: 0.7rem;
  }

  .footer-links a {
    width: fit-content;
    color: var(--color-text-muted);
  }

  .footer-links a:hover {
    color: var(--color-primary);
  }

  .contact-list a,
  .contact-list div {
    display: grid;
    gap: 0.15rem;
  }

  .contact-list strong {
    font-size: 0.85rem;
  }

  .contact-list span {
    color: var(--color-text-muted);
    overflow-wrap: anywhere;
  }

  .social-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 1.25rem;
  }

  .social-links a {
    padding: 0.4rem 0.7rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-background);
    color: var(--color-text-muted);
    font-size: 0.8rem;
    font-weight: 700;
  }

  .social-links a:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .footer-bottom {
    display: grid;
    gap: 1rem;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }

  .footer-bottom p {
    margin: 0;
  }

  .footer-bottom nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-bottom a:hover {
    color: var(--color-primary);
  }

  @media (min-width: 700px) {
    .footer-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .footer-bottom {
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: center;
    }
  }

  @media (min-width: 1050px) {
    .footer-grid {
      grid-template-columns:
        minmax(280px, 1.5fr)
        repeat(3, minmax(150px, 1fr));
    }
  }

  @media (max-width: 640px) {
    .site-footer {
      padding-bottom: 6rem;
    }
  }
</style>