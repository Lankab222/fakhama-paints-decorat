---
interface Props {
  title: string;
  description: string;

  buttonText: string;
  buttonUrl: string;

  phone?: string;
  whatsapp?: string;
}

const {
  title,
  description,
  buttonText,
  buttonUrl,
  phone,
  whatsapp,
} = Astro.props;
---

<section class="section cta-section">
  <div class="container">
    <div class="cta-box">
      <div class="cta-content">
        <span>لنبدأ مشروعك</span>
        <h2>{title}</h2>
        <p>{description}</p>
      </div>

      <div class="cta-actions">
        <a class="cta-primary" href={buttonUrl}>
          {buttonText}
        </a>

        {
          whatsapp && (
            <a
              class="cta-secondary"
              href={`https://wa.me/${whatsapp}`}
              target="_blank"
              rel="noopener noreferrer"
            >
              تواصل عبر واتساب
            </a>
          )
        }

        {!whatsapp && phone && (
          <a class="cta-secondary" href={`tel:${phone}`}>
            اتصل بنا
          </a>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    background: var(--color-background);
  }

  .cta-box {
    position: relative;
    display: grid;
    gap: 2rem;
    overflow: hidden;
    padding: clamp(2rem, 6vw, 4rem);
    border-radius: 2rem;
    background:
      linear-gradient(
        135deg,
        var(--color-primary),
        color-mix(in srgb, var(--color-primary) 72%, black)
      );
    color: white;
    box-shadow:
      0 24px 60px
      color-mix(in srgb, var(--color-primary) 25%, transparent);
  }

  .cta-box::before {
    position: absolute;
    top: -8rem;
    left: -6rem;
    width: 20rem;
    height: 20rem;
    border: 1px solid rgb(255 255 255 / 18%);
    border-radius: 50%;
    content: "";
  }

  .cta-box::after {
    position: absolute;
    right: -4rem;
    bottom: -8rem;
    width: 16rem;
    height: 16rem;
    border-radius: 50%;
    background: rgb(255 255 255 / 8%);
    content: "";
  }

  .cta-content,
  .cta-actions {
    position: relative;
    z-index: 1;
  }

  .cta-content {
    max-width: 760px;
  }

  .cta-content > span {
    font-weight: 800;
    opacity: 0.82;
  }

  .cta-content h2 {
    margin-block: 0.65rem 1rem;
    font-size: clamp(2rem, 6vw, 3.8rem);
    line-height: 1.2;
  }

  .cta-content p {
    margin: 0;
    color: rgb(255 255 255 / 82%);
    font-size: 1.075rem;
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .cta-primary,
  .cta-secondary {
    display: inline-flex;
    min-height: 52px;
    align-items: center;
    justify-content: center;
    padding-inline: 1.35rem;
    border-radius: var(--radius-md);
    font-weight: 800;
  }

  .cta-primary {
    background: white;
    color: var(--color-primary);
  }

  .cta-secondary {
    border: 1px solid rgb(255 255 255 / 35%);
    background: rgb(255 255 255 / 10%);
    color: white;
  }

  @media (min-width: 900px) {
    .cta-box {
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: center;
    }

    .cta-actions {
      max-width: 300px;
      justify-content: flex-end;
    }
  }
</style>